# Dependencies and build output (reinstalled/rebuilt inside the image)
node_modules
dist
build

# Environment files — never bake secrets into the image; pass them at runtime
.env
.env.*
!.env.example

# Logs and misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# VCS and editor
.git
.gitignore
.vscode

# Daytona SDK and sandbox artifacts
.daytona/
sandbox/
