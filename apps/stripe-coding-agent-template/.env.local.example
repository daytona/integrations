# This is what `stripe projects env --pull` writes into .env.local after you
# provision the services. The app reads these prefixed names directly (it bridges
# them to what the SDKs expect), so you normally don't edit this file by hand —
# it's here to show the shape of a provisioned environment.

# ── Daytona (stripe projects add daytona/sandbox) ───────────────────────────
DAYTONA_SANDBOX_API_KEY=
DAYTONA_SANDBOX_API_URL=
DAYTONA_SANDBOX_ORGANIZATION_ID=
DAYTONA_SANDBOX_SANDBOX_ID=
DAYTONA_SANDBOX_TOOLBOX_PROXY_URL=

# ── OpenRouter (stripe projects add openrouter/api) ─────────────────────────
# Expected name (pending confirmation with Stripe). The app reads OPENROUTER_API_KEY
# and also auto-discovers any OPENROUTER_*_API_KEY, so a prefixed variant works too.
OPENROUTER_API_KEY=

# ── Vercel (stripe projects add vercel/project) ─────────────────────────────
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_ORG_ID=
VERCEL_PROJECT_URL=
VERCEL_URL=
