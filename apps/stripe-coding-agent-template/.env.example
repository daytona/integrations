# ─────────────────────────────────────────────────────────────────────────────
# Daytona Coding Agent — environment
#
# Two ways to fill this in:
#   A) Stripe Projects (recommended) — provision the services, then run
#      `stripe projects env --pull`. The pulled, service-prefixed variables
#      (DAYTONA_SANDBOX_*, OPENROUTER_*, VERCEL_*) land in .env.local and are
#      read directly by the app; you do NOT need to copy them into the
#      unprefixed names below. See .env.local.example for what gets pulled.
#   B) Manual — paste raw keys into the unprefixed variables yourself.
# ─────────────────────────────────────────────────────────────────────────────

# ── Daytona (code execution) ────────────────────────────────────────────────
# A)  stripe projects add daytona/top-up-0025   # an active plan is required first
#     stripe projects add daytona/sandbox
#     stripe projects env --pull
#     → exports DAYTONA_SANDBOX_API_KEY / DAYTONA_SANDBOX_API_URL /
#       DAYTONA_SANDBOX_ORGANIZATION_ID, which this app reads automatically.
#
# B)  Manual: get a key at https://app.daytona.io/dashboard/keys
DAYTONA_API_KEY=
# Optional. Defaults to https://app.daytona.io/api when unset.
DAYTONA_API_URL=
# Optional. Only needed for org-scoped keys.
DAYTONA_ORGANIZATION_ID=

# ── OpenRouter (LLM brain) ──────────────────────────────────────────────────
# A)  stripe projects add openrouter/api
#     stripe projects env --pull
#     → exports an OPENROUTER_*_API_KEY, which this app discovers automatically.
#
# B)  Manual: create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional. Any model id from https://openrouter.ai/models.
# Default: anthropic/claude-sonnet-4.5
OPENROUTER_MODEL=

# Optional. OpenAI-compatible base URL. Default: https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=

# Optional. Attribution shown on your OpenRouter activity dashboard.
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# ── Vercel (hosting) ────────────────────────────────────────────────────────
# Needed only for `npm run deploy`. Provision with `stripe projects add
# vercel/project` then `stripe projects env --pull` to populate these.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_ORG_ID=
VERCEL_PROJECT_URL=
VERCEL_URL=

# Optional. Names the Vercel deployment (defaults to the folder name).
NEXT_PUBLIC_APP_NAME=
